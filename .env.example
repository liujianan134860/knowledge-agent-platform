# ============================================================
# DeepSeek LLM (chat / tool-calling)
# ============================================================
# NOTE: deepseek-v4-pro has "thinking mode" which requires reasoning_content
# to be passed back across multi-turn calls (tool calling). Use deepseek-chat
# if you encounter "reasoning_content must be passed back" errors.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Set to false to disable the reasoning_content advisor for deepseek-v4-pro
# DEEPSEEK_REASONING_ENABLED=true

# ============================================================
# GitHub MCP (tool-calling integration)
# ============================================================
# WARNING: GitHub Copilot MCP server only supports POST (JSON-RPC), NOT SSE.
# Spring AI 1.1.4 streamable-http transport requires SSE → 405 error.
# The MCP client initializes but cannot list tools. Upgrade Spring AI to 1.2+
# with pure HTTP POST transport, or enable GITHUB_MCP_HTTP_ENABLED below.
GITHUB_MCP_ENABLED=false
GITHUB_MCP_HTTP_ENABLED=false
GITHUB_MCP_TOKEN=your_github_token_here
GITHUB_MCP_URL=https://api.githubcopilot.com
GITHUB_MCP_ENDPOINT=/mcp/
GITHUB_MCP_TOOLSETS=repos,issues,pull_requests
GITHUB_MCP_READONLY=1
GITHUB_MCP_REQUEST_TIMEOUT=30s

# ============================================================
# Alibaba Cloud Bailian / DashScope
# QWEN_API_KEY can be reused by judge, rerank, and embedding.
# ============================================================
QWEN_API_KEY=your_bailian_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_JUDGE_TIMEOUT_SECONDS=30
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1536
QWEN_JUDGE_MODEL=qwen3.6-plus
BAILIAN_RERANK_MODEL=qwen3-rerank
BAILIAN_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
BAILIAN_RERANK_TIMEOUT_SECONDS=30

# ============================================================
# Auth / JWT
# ============================================================
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRATION_MS=86400000
REFRESH_TOKEN_EXPIRATION_MS=604800000

# ============================================================
# Server
# ============================================================
PORT=8081

# ============================================================
# AI Platform Tuning (optional, defaults shown)
# ============================================================
# PROMPT_VERSION=prompt-v1
# RETRIEVAL_VERSION=hybrid-v1
# RETRIEVAL_TOP_K=3
# LLM_JUDGE_ENABLED=true
# RERANK_ENABLED=true
# RERANK_CANDIDATE_MULTIPLIER=4
# MODEL_MAX_ATTEMPTS=2
# MODEL_CIRCUIT_BREAKER_THRESHOLD=3
# MODEL_CIRCUIT_BREAKER_OPEN_MS=30000
